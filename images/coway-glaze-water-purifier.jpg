function formValidate(btnType) {

var fileinputstatus = true;
var fileinputcombine = "";

$('input[name^="fileuniqueinput"]').each(function() {
    var $input = $(this);
    var excl = false;
  
    if ($input.attr("id") != "fileuniqueinput") 
    {
        if ($('#ForeignerField1').length > 0) {
            if ($('#ForeignerField1').css('display') == "none") {
                $('#ForeignerField1 input').each(function() {
                    var $excludeInput = $(this);
                    if ($excludeInput.attr('id') == $input.attr("id")) {
                        excl = true;
                    }
                });
            }
        }

        if (!excl) 
        {
            $files = $input[0].files;
            if (typeof $files != "undefined") 
            {
                for (var i = 0; i < $files.length; i++) {
                    fileinputcombine += $input.attr("id") + "$" + $files[i].name + ",";
                }
            }

            if ($input.val() == "") {
                $('span[data-valmsg-for=' + $input.attr("id") + ']').html('<span>' + $input.attr("data-val-required") + '</span>');
                fileinputstatus = false;
            } else {
                $('span[data-valmsg-for=' + $input.attr("id") + ']').html('');
            }
        }
    }
});

$("#DynamicFormFileInputField").val(fileinputcombine);

if(!fileinputstatus)
{
	return false;
}


 $('#callmebackcaptchaerror').html("");
 //$('#captchaError').html("");
 $('#captchaErrorCareer').html("");
 $('#captchaTradeInError').html("");
 $('#captchaWowPlanError').html("");
 $('#captchaDynamicFormError').html("");
 $('#captchaTopicFormError').html("");

 if (grecaptcha.getResponse(recaptchaloyaltyform) == "" && btnType == "loyalty") {
  $('#callmebackcaptchaerror').html(validateMessageFail);
  grecaptcha.reset();
  return false;
 }
 //else if (grecaptcha.getResponse(recaptchaenquiry) == "" && btnType == "1") {$('#captchaError').html(validateMessageFail); grecaptcha.reset(); return false; }
 else if (grecaptcha.getResponse(recaptchacareerform) == "" && btnType == "career") {
  $('#captchaErrorCareer').html(validateMessageFail);
  grecaptcha.reset();
  return false;
 } else if (grecaptcha.getResponse(recaptchatradeinform) == "" && btnType == "tradein") {
  $('#captchaTradeInError').html(validateMessageFail);
  grecaptcha.reset();
  return false;
 } else if (grecaptcha.getResponse(recaptchawowplanform) == "" && btnType == "wowplan") {
  $('#captchaWowPlanError').html(validateMessageFail);
  grecaptcha.reset();
  return false;
 } else if (grecaptcha.getResponse(recaptchadynamicform) == "" && btnType == "dynamic") {
  $('#captchaDynamicFormError').html(validateMessageFail);
  grecaptcha.reset();
  return false;
 } else if (grecaptcha.getResponse(recaptchadynamicform) == "" && btnType == "dynamicmco") {
  $('#captchaDynamicFormError').html(validateMessageFail);
  grecaptcha.reset();
  return false;
} else if (grecaptcha.getResponse(recaptchatopicsolutionform) == "" && btnType == "topicsolution") {
     $('#captchaTopicFormError').html(validateMessageFail);
     console.log("here");
     grecaptcha.reset();
     return false;
    }

    if (btnType == "topicsolution")
    {
        $(".state-selection #State").val($("#display-state-dropdown-value").val());
        $("#TopicSelection").val($("#display-dropdown-id").val());

    if ($("#TopicSolutionForm").valid()) {
        var myData = $('#TopicSolutionForm').serialize();
        $.ajax({
        type: "POST",
            url: '/insertTopicEnquiry',
            dataType: "json",
            data: myData,
            success: function (response) {
        console.log(response);
                $("#topic-form-inner-wdg").fadeOut();
                $("#topic-form-thankyou").fadeIn();
            },
            error: function () {console.log("topic form error"); }
        });
        return false;
    } else {
        return false;
    }
}


 if (btnType == "dynamic" || btnType == "dynamicmco") {
  var tncId = [];
  $("#tncerror").html("");
  $("#wrapping-form").find(':input').each(function() {
   var $thisInput = $(this);
   if ($thisInput.attr("id") != "btnSubmit" && $thisInput.attr("id") != "Permalink" && $thisInput.attr("id") != "DynamicFormField") {
    if ($thisInput.attr("type") == "checkbox") {
     if (!$thisInput.prop("checked")) {
      var requiredText = $thisInput.attr("data-errormsgrequired");
      tncId.push($thisInput.attr("id"));
      setTimeout(function() {
       $("p[data-valmsg-for='" + $thisInput.attr("id") + "']").html("<span id='" + $thisInput.attr("id") + "-error' class='' >" + requiredText + "</span >");
       $("p[data-valmsg-for='" + $thisInput.attr("id") + "']").removeClass("hidden");
      }, 500);
     } else {
      tncId.push($thisInput.attr("id"));
     }
    }
   }
  });

  var x = $("#dynamic-form form").serializeArray();
  var formType = $("#dynamic-form").data("type");
  if (typeof formType !== 'undefined') {
   $("#formType").val(formType);
  } else {
   $("#formType").val(""); //sure is dynamic form
  }
  var formsData = "";
  $.each(x, function(i, field) {
   if (field.name != "g-recaptcha-response" && field.name != "Permalink" && field.name != "DynamicFormField") {
    if (tncId.indexOf(field.name) >= 0) {
     if (field.value == "on") {
      field.value = "Yes-check";
     } else {
      field.value = "No-check";
     }
    }
    formsData += field.name + ":" + removeEmojis(field.value.replace(/\*/g, '').trim()) + "*";
   }
  });

  $("#DynamicFormField").val(formsData.substring(0, formsData.length - 1));

  if ($("#dynamic-form form").valid()) {
   var found = true;
   tncId.forEach(function(value) {
   if(typeof value != 'undefined'){
    if (!$("#wrapping-form").find("input[id='" + value + "']").prop("checked")) {
     found = false;
    }
    }
   });

   if (btnType == "dynamicmco" && found) {
    $("#confirmationModal").modal("show");
    return false;
   }

   return found;
  }
 }
}

$(".ads .modal-content").css("background-color", "transparent");

function removeEmojis(string) {
 var regex = /(?:[\u2700-\u27bf]|(?:\ud83c[\udde6-\uddff]){2}|[\ud800-\udbff][\udc00-\udfff]|[\u0023-\u0039]\ufe0f?\u20e3|\u3299|\u3297|\u303d|\u3030|\u24c2|\ud83c[\udd70-\udd71]|\ud83c[\udd7e-\udd7f]|\ud83c\udd8e|\ud83c[\udd91-\udd9a]|\ud83c[\udde6-\uddff]|\ud83c[\ude01-\ude02]|\ud83c\ude1a|\ud83c\ude2f|\ud83c[\ude32-\ude3a]|\ud83c[\ude50-\ude51]|\u203c|\u2049|[\u25aa-\u25ab]|\u25b6|\u25c0|[\u25fb-\u25fe]|\u00a9|\u00ae|\u2122|\u2139|\ud83c\udc04|[\u2600-\u26FF]|\u2b05|\u2b06|\u2b07|\u2b1b|\u2b1c|\u2b50|\u2b55|\u231a|\u231b|\u2328|\u23cf|[\u23e9-\u23f3]|[\u23f8-\u23fa]|\ud83c\udccf|\u2934|\u2935|[\u2190-\u21ff])/g;
 return string.replace(regex, '');
}

$(document).ready(function() {
 //return false only for spec and price button
 $('.specs-and-price a[data-toggle="modal"]').click(function(e) {
  return false;
 });

 //return false for spec and price tab button
 $('a[data-toggle="tab"]').on('click', function(e) {
  var tab = e.target.hash;
  $('a[href="' + tab + '"]').tab("show");
  return false;
 });

 //all modal button click
 $('a[data-toggle="modal"]').click(function() {

  if (typeof $(this).attr('data-titlehash') != 'undefined') // add hash
  {
   window.location.hash = '#' + $(this).attr('data-titlehash');
  } else // remove hash
  {
   window.location.hash = '';
  }

  $("#modal-wrapper .close-modal").removeAttr("href"); // remove modal close button href
  $("#modal-wrapper .close-modal").click(function() { // during click remove hash from url
   if (typeof window.location.href.split('#')[1] != 'undefined' || window.location.href.split('#')[1] != '') {
    window.history.pushState(null, null, window.location.href.split('#')[0]);
   }
  });
 });

 //on loads show modal
 if (typeof window.location.href.split('#')[1] != 'undefined' || window.location.href.split('#')[1] != '') {
  setTimeout(function() {
   $($("a[data-titlehash='" + window.location.href.split('#')[1] + "']").attr("data-target")).modal("show");
  }, 1100);
 }
});

$('#service').find("a:first").click(function() {
 return false;
});

var salaryText = $(".career-details .salary").html();
if (salaryText == "-") {
 $(".career-details .salary").hide();
}
</script>


    <script>
        var delete_cookie = function (name) {
            document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:01 GMT;path=/;';
        };

        function getParameterByName(name, url) {
            if (!url) url = window.location.href;
            name = name.replace(/[\[\]]/g, "\\$&");
            var regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
                results = regex.exec(url);
            if (!results) return null;
            if (!results[2]) return '';
            return decodeURIComponent(results[2].replace(/\+/g, " "));
        }

        function getCookie(cname) {
            var name = cname + "=";
            var ca = document.cookie.split(';');
            for (var i = 0; i < ca.length; i++) {
                var c = ca[i];
                while (c.charAt(0) == ' ') {
                    c = c.substring(1);
                }
                if (c.indexOf(name) == 0) {
                    return c.substring(name.length, c.length);
                }
            }
            return "";
        }

        function createCookie(name, value, days) {
            if (days) {
                var date = new Date();
                date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                var expires = "; expires=" + date.toGMTString();
            }
            else var expires = "";
            document.cookie = name + "=" + value + expires + "; path=/";
        }

        var curday = function (sp) {
            today = new Date();
            var dd = today.getDate();
            var mm = today.getMonth() + 1; //As January is 0.
            var yyyy = today.getFullYear();

            if (dd < 10) dd = '0' + dd;
            if (mm < 10) mm = '0' + mm;
            return (dd + sp + mm + sp + yyyy);
        };

        $(document).ready(function () {
            $(".product-new.section-6 .row .col-sm-4.wdg-wrapper").matchHeight();

            if (!''.includes("support/product") && !''.includes("mattress-careservice/500freetrial")) {
                 // nav active
                var someStringValue = '';
                if (someStringValue != "") {
                    if ($("#" + someStringValue).length == 1) {
                        $("#" + someStringValue).addClass('active');
                    }
                    else {
                        //find the top first li
                        $("a[href=" + someStringValue + "]").parents("li").last().addClass('active');
                    }
                }
            }

            var PageTakeOverStatus = '';
            if (PageTakeOverStatus != "") {
                if (PageTakeOverStatus == "Show") {
                    //console.log("here");
                    $("#advance-ads .modal-body").html("");
                    $("#advance-ads .modal-body").html('');
                    //setTimeout(function () {
                        $("#advance-ads").modal("show");
                    //}, 1000);

                }
            }

            var careerTitle = getParameterByName('title');
            if (typeof(careerTitle) != "undefined")
            {
                if(careerTitle != null)
                {
                    if (careerTitle != "")
                    {
                        $("#hfcareertitle").val(careerTitle);
                    }
                }
            }

            //check if mobile
            var isMobileMenu = {
                Android: function () {
                    return navigator.userAgent.match(/Android/i);
                },
                BlackBerry: function () {
                    return navigator.userAgent.match(/BlackBerry/i);
                },
                iOS: function () {
                    return navigator.userAgent.match(/iPhone|iPad|iPod/i);
                },
                Opera: function () {
                    return navigator.userAgent.match(/Opera Mini/i);
                },
                Windows: function () {
                    return navigator.userAgent.match(/IEMobile/i);
                },
                any: function () {
                    return (isMobileMenu.Android() || isMobileMenu.BlackBerry() || isMobileMenu.iOS() || isMobileMenu.Opera() || isMobileMenu.Windows());
                }
            };

            if (isMobileMenu.any()) {
                if ($("#navbar-collapse ul li").length > 0)
                {
                    $("#navbar-collapse ul li").each(function () {
                        var $thisMenu = $(this);
                        if ($thisMenu.find(".sub-menu-wrapper").length > 0)
                        {
                            $thisMenu.find("a:first").attr("href", "#");
                        }
                    });
                }
            }
        });

        function detectIE() {
            var ua = window.navigator.userAgent;

            // Test values; Uncomment to check result …

            // IE 10
            // ua = 'Mozilla/5.0 (compatible; MSIE 10.0; Windows NT 6.2; Trident/6.0)';

            // IE 11
            // ua = 'Mozilla/5.0 (Windows NT 6.3; Trident/7.0; rv:11.0) like Gecko';

            // Edge 12 (Spartan)
            // ua = 'Mozilla/5.0 (Windows NT 10.0; WOW64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/39.0.2171.71 Safari/537.36 Edge/12.0';

            // Edge 13
            // ua = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/46.0.2486.0 Safari/537.36 Edge/13.10586';

            var msie = ua.indexOf('MSIE ');
            if (msie > 0) {
                // IE 10 or older => return version number
                return parseInt(ua.substring(msie + 5, ua.indexOf('.', msie)), 10);
            }

            var trident = ua.indexOf('Trident/');
            if (trident > 0) {
                // IE 11 => return version number
                var rv = ua.indexOf('rv:');
                return parseInt(ua.substring(rv + 3, ua.indexOf('.', rv)), 10);
            }

            var edge = ua.indexOf('Edge/');
            if (edge > 0) {
                // Edge (IE 12+) => return version number
                return parseInt(ua.substring(edge + 5, ua.indexOf('.', edge)), 10);
            }

            // other browser
            return false;
        }

        $('.input-filename').click(function () {

            var version = detectIE();
            if (version != false)
            {
                var $getVal = $('#ResumeFile').val();
                $('#ResumeFile').change(function (evt) {
                    var $getVal = $(this).val().substring(12);
                    $('.input-filename').html($getVal.split("\\").pop());
                });
                $('#ResumeFile').trigger("click");
            }
            else
            {
                var $getVal = $('#ResumeFile').val();
                $('#ResumeFile').trigger("click");
                $('#ResumeFile').change(function (evt) {
                    var $getVal = $(this).val().substring(12);
                    $('.input-filename').html($getVal);
                });
            }
        });

        //get file path from client system
        function getNameFromPath(strFilepath) {
            var objRE = new RegExp(/([^\/\\]+)$/);
            var strName = objRE.exec(strFilepath);

            if (strName == null) {
                return null;
            }
            else {
                return strName[0];
            }
        }

        $(function () {
            $("#ResumeFile").change(function () {
                var file = getNameFromPath($(this).val());
                if (file != null) {
                    var extension = file.substr((file.lastIndexOf('.') + 1));
                    switch (extension) {
                        case 'pdf':
                        case 'docx':
                        case 'doc':
                        case 'xlsx':
                        case 'xls':
                        case 'csv':
                        case 'txt':
                            flag = true;
                            break;
                        default:
                            flag = false;
                    }
                }
                if (flag == false) {
                    $("#uploadResume > span").html("");
                    $("#uploadResume > span").html("You can upload only pdf,docx,doc,xlsx,xls,csv,txt extension file");
                    return false;
                }
                else {
                    $("#uploadResume > span").html("");
                    if (this.files[0].size / 1024 / 1024 > 4) {
                        $("#uploadResume > span").html("You can upload file up to 4 MB");
                        return false
                    }
                }
            });
        });

