        //hash click on special menu
	    $(".special-hashclick").click(function (e) {
            e.preventDefault();
            var $this = $(this);
            var href = $this.attr("href");
            if (href.indexOf("#") > -1) {
                if (href.indexOf("http") > -1 || href.indexOf("https") > -1) {
                    window.location.href = href;
                }
                else
                {
                    //window.location = href.replace(/^\/+/g, '');
                    //window.location.reload();
                    window.location.href = 'https://www.coway.com.my/' + href.replace(/^\/+/g, '');
                }
            }
            else {
                if (href.indexOf("http") > -1 || href.indexOf("https") > -1) {
                    return window.location.href = href;
                }
                else {
                    return window.location.href = 'https://www.coway.com.my' + href;
                }
            }
            showModal();
        });

        function showModal()
        {
            if (typeof window.location.href.split('#')[1] != 'undefined' || window.location.href.split('#')[1] != '')
            {
                $($("a[data-titlehash='" + window.location.href.split('#')[1] + "']").attr("data-target")).modal("show");
            }
        }
		
		 $(document).ready(function () {
            if (typeof window.location.href.split('#')[1] != 'undefined' && window.location.href.split('#')[1] != '') {
                setTimeout(function () {
                    const headerHeight = $('.mobile-navigation').height();
                    $('html, body').animate({
                        scrollTop: $("#" + window.location.href.split('#')[1]).offset().top - headerHeight
                    }, 400);
                }, 500);
            }
        });
    </script>


    

    

    
