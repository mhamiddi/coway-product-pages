        //Dynamic Error Message
        $("#wrapping-form").wrap("<form action=\"/dynamicform\" class=\"form-horizontal\" id=\"DynamicForm\" method=\"post\" role=\"form\" novalidate=\"novalidate\" enctype=\"multipart/form-data\"></form>");
        if ($("#wrapping-form").length > 0) {
            var $thisForm = $("#wrapping-form");
            if ($thisForm.find(':input').length > 0) {
                $thisForm.find(':input').each(function () {
                    var $thisInput = $(this);
                    if ($thisInput.attr("id") != "btnSubmit" && $thisInput.attr("id") != "Permalink" && $thisInput.attr("id") != "DynamicFormField") {
                        var requiredText = $thisInput.attr("data-errormsgrequired");
                        var emailValid = $thisInput.attr("data-errormsginvalidemail");
                        if (requiredText != null && requiredText != "") {
                            $thisInput.attr("data-val-required", requiredText);

                            if ($thisInput.attr("type") == "checkbox") {
                                $thisInput.on("change", function () {
                                    if ($(this).prop("checked")) {
                                        $("p[data-valmsg-for='" + $thisInput.attr("id") +"']").addClass("hidden");
                                    }
                                });
                            }
                        }
                        if (emailValid != null && emailValid != "") {
                            $thisInput.attr("data-val-email", emailValid)
                        }
                    }
                });
                $thisForm.find('textarea').each(function () {
                    var $thisInput = $(this);
                    if ($thisInput.attr("id") != "btnSubmit" && $thisInput.attr("id") != "Permalink" && $thisInput.attr("id") != "DynamicFormField") {
                        var requiredText = $thisInput.attr("data-errormsgrequired");
                        if (requiredText != null && requiredText != "") {
                            $thisInput.attr("data-val-required", requiredText);
                        }
                    }
                });
            }
        }

        if ($("#wrapping-form").length > 0) {
            $(".EnquirySelectionInput").change(function (e) {
                e.preventDefault();
                var $this = $(this);

                var data = JSON.stringify({
                    'enquiryvalue': $this.find(":selected").text()
                });
                $.ajax({
                    type: "POST",
                    url: '/enquiryddlhtml',
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    data: data,
                    success: function (response) {
                        $("#extraHTML").html("");
                        $("#extraHTML").html(response.datahtml);

                        $(response.datahtml).find("input").each(function () {
                            var $input = $(this);
                            if (typeof $input.data("errormsgrequired") != "undefined") {
                                $('#' + $input.attr("id")).rules("add", {
                                    required: true,
                                    messages: {
                                        required: $input.data("errormsgrequired")
                                    }
                                });
                            }

                            if (typeof $input.data("errormsginvalidemail") != "undefined") {
                                $('#' + $input.attr("id")).attr("data-val-email", $input.data("errormsginvalidemail"))
                                $('#' + $input.attr("id")).rules("add", {
                                    email:true,
                                    messages: {
                                        email: $input.data("errormsginvalidemail")
                                    }
                                });
                            }
                        });

                        $('input.unique-daterange').daterangepicker({
                            opens: 'left',
                            locale: {
                                format: 'DD-MM-YYYY',
                                separator: " to "
                            }
                        }, function (start, end, label) {
                            //console.log("A new date selection was made: " + start.format('DD-MM-YYYY') + ' to ' + end.format('DD-MM-YYYY'));
                        });
                    },
                    error: function () { alert('Error occoured'); }
                });
            });
        }

